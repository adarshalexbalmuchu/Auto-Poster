# ─── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── LinkedIn Developer App ─────────────────────────────────────────────────────
# https://www.linkedin.com/developers/apps/new
# Scopes needed: openid, profile, w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback

# ─── WhatsApp Cloud API ─────────────────────────────────────────────────────────
# https://developers.facebook.com/apps → your app → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Your personal WhatsApp number in E.164 format (country code + number, no +)
# e.g. India 91XXXXXXXXXX
WHATSAPP_RECIPIENT_NUMBER=

# ─── App settings ───────────────────────────────────────────────────────────────
PORT=3000

# ─── Auto-posting (used by scheduler) ───────────────────────────────────────────
# Set to "true" to post immediately when scheduler runs (instead of just saving a draft)
AUTO_POST=false

# ─── Dashboard auth (optional basic password for the web dashboard) ─────────────
DASHBOARD_PASSWORD=

# ─── Frontend URL (used for CORS — set to your GitHub Pages URL in production) ──
# e.g. https://adarshalexbalmuchu.github.io
FRONTEND_URL=
