# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn — one set per client (irfan / alex)
IRFAN_LINKEDIN_ACCESS_TOKEN=
IRFAN_LINKEDIN_PERSON_URN=urn:li:person:...
IRFAN_LINKEDIN_TOKEN_EXPIRES_AT=2026-09-01

ALEX_LINKEDIN_ACCESS_TOKEN=
ALEX_LINKEDIN_PERSON_URN=urn:li:person:...
ALEX_LINKEDIN_TOKEN_EXPIRES_AT=2026-09-01

# LinkedIn OAuth app credentials (used by src/auth.js)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT_NUMBER=919...    # E.164 without +

# Cloudflare Worker callback (set in GitHub Actions secrets too)
WORKER_URL=https://auto-poster-webhook.<your-subdomain>.workers.dev
WORKER_CALLBACK_SECRET=
