# ─── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── LinkedIn Developer App ─────────────────────────────────────────────────────
# https://www.linkedin.com/developers/apps/new
# Scopes needed: openid, profile, w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback

# ─── App settings ───────────────────────────────────────────────────────────────
PORT=3000

# ─── Auto-posting (used by scheduler) ───────────────────────────────────────────
# Set to "true" to post immediately when scheduler runs (instead of just saving a draft)
AUTO_POST=false

# ─── Dashboard auth (optional basic password for the web dashboard) ─────────────
DASHBOARD_PASSWORD=
